# Crypto Exchange MCP Server Configuration
# Copy this file to .env and fill in your API credentials

# ===== Bybit =====
# Get API keys from: https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here

# ===== Binance =====
# Get API keys from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# ===== OKX =====
# Get API keys from: https://www.okx.com/account/my-api
OKX_API_KEY=your_okx_api_key_here
OKX_API_SECRET=your_okx_api_secret_here
OKX_PASSPHRASE=your_okx_passphrase_here

# ===== External MCP aggregation =====
# Built-in child MCP definitions are enabled by default:
# - bybit: npx -y bybit-official-trading-server@latest
# - okx: npx -y @okx_ai/okx-trade-mcp@latest --modules market --read-only
# - binance: uvx --from binance-mcp-server binance-mcp-server
CRYPTO_EXCHANGE_MCP_ENABLE_DEFAULTS=true

# Optional JSON file to override/add child MCP server definitions.
# CRYPTO_EXCHANGE_MCP_CONFIG=/absolute/path/to/external-mcp.json

# Optional per-call timeout for child MCP list/call operations.
CRYPTO_EXCHANGE_MCP_TIMEOUT_SECONDS=60
